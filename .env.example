# Copy to .env.local for local dev, and set these in your host (e.g. Vercel) for production.

# --- Database ---
# Local dev uses the SQLite file in prisma/ (see prisma/schema.prisma), so no
# DATABASE_URL is needed locally today. For a multi-device production deploy,
# switch the Prisma provider to postgresql and set this to your hosted DB URL
# (see DEPLOY.md).
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# --- Auth (single password) ---
# Leave BOTH unset to disable the login gate (open app — fine for local dev).
# Set APP_PASSWORD in production to require this password before anyone can use
# the app. SESSION_SECRET signs the login cookie; use a long random string.
# APP_PASSWORD="choose-a-strong-password"
# SESSION_SECRET="a-long-random-string-at-least-32-chars"
